{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "agent:dev": "tsx --env-file=.env src/agent/index.ts dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run agent:dev\"",
    "seed": "tsx --env-file=.env src/scripts/seed.ts",
    "build": "tsc",
    "server:start": "node dist/server.js",
    "agent:start": "node --max-old-space-size=2048 dist/agent/index.js start",
    "start": "npm run agent:start",
    "start:all": "concurrently \"npm run start\" \"npm run agent:start\"",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@livekit/agents": "^1.5.2",
    "@livekit/agents-plugin-deepgram": "^1.5.2",
    "@livekit/agents-plugin-google": "^1.5.2",
    "@livekit/agents-plugin-openai": "^1.5.2",
    "@livekit/rtc-node": "^0.13.31",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "http-status-codes": "^2.3.0",
    "livekit-server-sdk": "^2.17.0",
    "mongoose": "^9.7.4",
    "redis": "^6.1.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2"
  }
}
